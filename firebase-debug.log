[debug] [2026-04-13T18:01:06.597Z] >>> [apiv2][body] PUT http://127.0.0.1:8081/emulator/v1/projects/civco-a947d:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n\r\n    // AU003 - Solo correos institucionales del ITCR pueden acceder.\r\n    function isAuthenticated() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    function hasInstitutionalEmail() {\r\n      return request.auth.token.email.matches('.*@estudiantec\\\\.cr$')\r\n          || request.auth.token.email.matches('.*@itcr\\\\.ac\\\\.cr$');\r\n    }\r\n\r\n    function isOwner(userId) {\r\n      return request.auth.uid == userId;\r\n    }\r\n\r\n    // AU004 - Verifica si el usuario autenticado tiene rol de administrador.\r\n    function isAdmin() {\r\n      return isAuthenticated()\r\n          && hasInstitutionalEmail()\r\n          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\r\n    }\r\n\r\n    // Perfiles de usuario\r\n    match /users/{userId} {\r\n      // AU004 - El propietario puede leer/editar su propio perfil; el admin puede leer/editar cualquiera.\r\n      allow read:   if isAuthenticated() && hasInstitutionalEmail() && (isOwner(userId) || isAdmin());\r\n      allow create: if isAuthenticated() && isOwner(userId) && hasInstitutionalEmail();\r\n      allow update: if isAuthenticated() && hasInstitutionalEmail() && (isOwner(userId) || isAdmin());\r\n      allow delete: if false;\r\n    }\r\n\r\n    // Préstamos de equipos\r\n    match /prestamos/{prestamoId} {\r\n      // REGLAS ORIGINALES\r\n      // allow read:   if isAuthenticated() && hasInstitutionalEmail();\r\n      // allow create: if isAuthenticated() && hasInstitutionalEmail();\r\n      // allow update: if isAuthenticated() && hasInstitutionalEmail();\r\n\r\n      // REGLAS TEMPORALES PARA DESARROLLO EN EMULATOR\r\n      allow read:   if true;\r\n      allow create: if true;\r\n      allow update: if true;\r\n\r\n      allow delete: if false;\r\n    }\r\n\r\n    // Devoluciones de equipos\r\n    match /devoluciones/{devolucionId} {\r\n      // REGLAS TEMPORALES PARA DESARROLLO EN EMULATOR\r\n      allow read:   if true;\r\n      allow create: if true;\r\n      allow update: if true;\r\n\r\n      allow delete: if false;\r\n    }\r\n\r\n    // Activos/equipos — solo lectura para usuarios institucionales\r\n    match /activos/{activoId} {\r\n      allow read:   if isAuthenticated() && hasInstitutionalEmail();\r\n      allow write:  if false; // Gestión reservada al Admin SDK\r\n    }\r\n  }\r\n}"}]}}
