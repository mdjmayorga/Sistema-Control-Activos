rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // AU003 - Solo correos institucionales del ITCR pueden acceder.
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasInstitutionalEmail() {
      return request.auth.token.email.matches('.*@estudiantec\\.cr$')
          || request.auth.token.email.matches('.*@itcr\\.ac\\.cr$');
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // AU004 - Verifica si el usuario autenticado tiene rol de administrador.
    function isAdmin() {
      return isAuthenticated()
          && hasInstitutionalEmail()
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Perfiles de usuario
    match /users/{userId} {
      // AU004 - El propietario puede leer/editar su propio perfil; el admin puede leer/editar cualquiera.
      allow read:   if isAuthenticated() && hasInstitutionalEmail() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && hasInstitutionalEmail();
      allow update: if isAuthenticated() && hasInstitutionalEmail() && (isOwner(userId) || isAdmin());
      allow delete: if false;
    }

    // Préstamos de equipos
    match /prestamos/{prestamoId} {
      // REGLAS ORIGINALES
      // allow read:   if isAuthenticated() && hasInstitutionalEmail();
      // allow create: if isAuthenticated() && hasInstitutionalEmail();
      // allow update: if isAuthenticated() && hasInstitutionalEmail();

      // REGLAS TEMPORALES PARA DESARROLLO EN EMULATOR
      allow read:   if true;
      allow create: if true;
      allow update: if true;

      allow delete: if false;
    }

    // Activos/equipos — solo lectura para usuarios institucionales
    match /activos/{activoId} {
      allow read:   if isAuthenticated() && hasInstitutionalEmail();
      allow write:  if false; // Gestión reservada al Admin SDK
    }
  }
}